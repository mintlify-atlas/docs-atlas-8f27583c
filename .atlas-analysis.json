  "keyFeatures": [
    "User authentication with admin and user roles",
    "Note creation with text, lists, and images",
    "Collection organization for grouping notes",
    "Friendship system with requests and acceptance",
    "Sharing notes and collections with friends",
    "Real-time notifications",
    "Admin dashboard for complete resource management",
    "Responsive design for all devices"
  ],
  "publicApiSurface": [
    "User (name, email, password, role)",
    "Note (title, content, user_id)",
    "Collection (name, notes, user_id)",
    "Friendship (user_id, friend_id, status)",
    "Sharing (owner, shared_with, shareable_type, shareable_id)",
    "Notification (user_id, message)",
    "POST /login - Authenticate user",
    "POST /signup - Register new user",
    "GET /logout - End user session",
    "CRUD /notes - Manage notes",
    "CRUD /collections - Manage collections",
    "CRUD /friendships - Manage friendships",
    "POST /sharing_create - Share content",
    "GET /getNotifications - Retrieve notifications"
  ]
